//@version=5
strategy("EMA Pullback Strategy", overlay=true, default_qty_type=strategy.percent_of_equity,
     default_qty_value=100, initial_capital=10000, commission_type=strategy.commission.percent,
     commission_value=0.04, slippage=1, pyramiding=0, calc_on_every_tick=false,
     process_orders_on_close=false)
//Created By: Wooanaz
//Created On: 8/8/2025
//Modified On: 3/6/2026
//Version: 3.2.0

// ╔══════════════════════════════════════════════════════════════╗
// ║                    PRESET SELECTOR                          ║
// ╚══════════════════════════════════════════════════════════════╝
preset = input.string("Custom", title="Preset", options=["Custom", "BTC Optimized", "ETH Optimized"], group="⚡ Preset", tooltip="Backtested presets auto-set EMA lengths, filters & risk params. Choose 'Custom' to use your own settings below.")

// ╔══════════════════════════════════════════════════════════════╗
// ║                    EMA & DISPLAY INPUTS                     ║
// ╚══════════════════════════════════════════════════════════════╝
fastLen_i    = input.int(50,  title="Fast EMA Length",  group="EMA Settings", tooltip="Shorter EMA reacts faster to price changes (ignored when preset is active)")
slowLen      = input.int(200, title="Slow EMA Length",  group="EMA Settings", tooltip="Longer EMA defines the major trend")
fastColor    = input.color(color.white, title="Fast EMA Color", group="EMA Settings")
slowColor    = input.color(color.red,   title="Slow EMA Color", group="EMA Settings")

showEmaFill  = input.bool(true,  title="Show EMA Ribbon Fill",                group="Display")
showLabels   = input.bool(true,  title="Show Golden/Death Labels",             group="Display")
showFastEmaPriceCrossSignals = input.bool(false, title="Show Price Crossing Fast EMA Signals", group="Display")
showSlowEmaPriceCrossSignals = input.bool(true,  title="Show Price Crossing Slow EMA Signals", group="Display")
showTrendBg  = input.bool(true,  title="Show Trend Background Color",          group="Display")
showDashboard = input.bool(true, title="Show Performance Dashboard",           group="Display")

// ╔══════════════════════════════════════════════════════════════╗
// ║                    SIGNAL FILTERS                           ║
// ╚══════════════════════════════════════════════════════════════╝
useCooldown           = input.bool(true,   title="Enable Cooldown Between Signals",  group="Filters", tooltip="Minimum 3 bars between same-direction signals")
filterSideways        = input.bool(true,   title="Suppress Signals in Sideways Market", group="Filters", tooltip="Blocks signals when EMAs are within 0.5% of each other")
useVolumeFilter       = input.bool(true,   title="Require Above-Average Volume",     group="Filters", tooltip="Signal only fires when volume > its 20-bar SMA")
useCandleConfirm      = input.bool(true,   title="Require Confirming Candle Body",   group="Filters", tooltip="Buy needs bullish close; sell needs bearish close")
useSlopeFilter        = input.bool(true,   title="Require EMA Slope Alignment",      group="Filters", tooltip="Slow EMA must be sloping in the trend direction over 10 bars")

useRsiFilter_i        = input.bool(false,  title="Enable RSI Filter",                group="Optional Filters", tooltip="Blocks buys above 70 RSI, sells below 30 RSI (auto-enabled by presets)")
rsiOverbought         = input.float(70.0, minval=50, maxval=100, title="RSI Overbought", group="Optional Filters")
rsiOversold           = input.float(30.0, minval=0,  maxval=50,  title="RSI Oversold",   group="Optional Filters")

useHtfFilter          = input.bool(false,  title="Enable Higher Timeframe Trend Filter", group="Optional Filters", tooltip="Only take signals when the HTF EMA trend agrees")
htfTimeframe          = input.timeframe("D", title="Higher Timeframe", group="Optional Filters")

useVixFilter          = input.bool(false,  title="Enable VIX Volatility Gate",           group="Market Context", tooltip="Pause all entries when VIX > threshold (fear/panic). Works for stocks & crypto.")
vixThreshold          = input.float(30.0, minval=10, maxval=80, step=1, title="VIX Max Threshold", group="Market Context", tooltip="Entries blocked when CBOE:VIX closes above this level")

useDxyFilter          = input.bool(false,  title="Enable DXY Dollar Filter",             group="Market Context", tooltip="Rising dollar is headwind for crypto & growth stocks. Uses 20-bar EMA slope.")
dxyMode               = input.string("Auto", title="DXY Mode", options=["Auto", "Bearish DXY = Buy Only", "Disabled"], group="Market Context", tooltip="Auto: rising DXY blocks longs for crypto, blocks all for stocks")

useBtcDomFilter       = input.bool(false,  title="Enable BTC Dominance Filter (Crypto)",  group="Market Context", tooltip="For altcoins (ETH/XRP): rising BTC.D = money flowing to BTC, blocks altcoin longs")
btcDomLen             = input.int(20, minval=5, maxval=100, title="BTC.D EMA Length", group="Market Context")

useSpyFilter          = input.bool(false,  title="Enable SPY/QQQ Market Regime (Stocks)", group="Market Context", tooltip="Only take stock longs when SPY is above its 50 EMA (risk-on)")
spyEmaLen             = input.int(50, minval=10, maxval=200, title="SPY EMA Length", group="Market Context")

useBtcTrendFilter     = input.bool(false,  title="Enable BTC Trend Filter (Crypto)",      group="Market Context", tooltip="For altcoins: only go long when BTC itself is in an uptrend (50 > 200 EMA)")

emaProximityThreshold = input.float(0.5, minval=0.01, step=0.01, title="Sideways Threshold %", group="Advanced", tooltip="EMAs closer than this % = sideways. Default 0.5%")

// ╔══════════════════════════════════════════════════════════════╗
// ║                    RISK MANAGEMENT                          ║
// ╚══════════════════════════════════════════════════════════════╝
useStopLoss      = input.bool(true,  title="Enable Stop Loss", group="Risk Management")
slType           = input.string("ATR", title="Stop Loss Type", options=["ATR", "Percent", "Swing"], group="Risk Management")
atrLen           = input.int(14, minval=1, title="ATR Length", group="Risk Management")
atrSlMult_i      = input.float(2.0, minval=0.1, step=0.1, title="ATR SL Multiplier", group="Risk Management", tooltip="ATR multiplier for stop loss (overridden by presets)")
slPercent        = input.float(2.0, minval=0.1, step=0.1, title="Stop Loss % (if Percent)", group="Risk Management")
swingLookback    = input.int(10, minval=2, title="Swing Lookback Bars (if Swing)", group="Risk Management")

useTakeProfit    = input.bool(true,  title="Enable Take Profit", group="Risk Management")
tpType           = input.string("Risk:Reward", title="Take Profit Type", options=["Risk:Reward", "ATR", "Percent"], group="Risk Management")
rrRatio_i        = input.float(2.0, minval=0.5, step=0.5, title="Risk:Reward Ratio", group="Risk Management", tooltip="R:R ratio for take profit (overridden by presets)")
atrTpMultiplier  = input.float(3.0, minval=0.1, step=0.1, title="ATR TP Multiplier", group="Risk Management")
tpPercent        = input.float(4.0, minval=0.1, step=0.1, title="Take Profit % (if Percent)", group="Risk Management")

useTrailingStop  = input.bool(false, title="Enable Trailing Stop", group="Risk Management")
trailType        = input.string("ATR", title="Trailing Stop Type", options=["ATR", "Percent"], group="Risk Management")
atrTrailMult     = input.float(1.5, minval=0.1, step=0.1, title="ATR Trail Multiplier", group="Risk Management")
trailPercent     = input.float(1.5, minval=0.1, step=0.1, title="Trail % (if Percent)", group="Risk Management")

// ╔══════════════════════════════════════════════════════════════╗
// ║              POSITION SIZING & TRADE DIRECTION              ║
// ╚══════════════════════════════════════════════════════════════╝
tradeDirection = input.string("Both", title="Trade Direction", options=["Long", "Short", "Both"], group="Position")
exitOnCross    = input.bool(true, title="Exit on EMA Death/Golden Cross", group="Position")

// ╔══════════════════════════════════════════════════════════════╗
// ║              DATE RANGE FILTER (BACKTESTING)                ║
// ╚══════════════════════════════════════════════════════════════╝
useDateFilter  = input.bool(false, title="Enable Date Range Filter", group="Backtest Range")
startDate      = input.time(timestamp("2020-01-01"), title="Start Date", group="Backtest Range")
endDate        = input.time(timestamp("2030-12-31"), title="End Date",   group="Backtest Range")
inDateRange    = not useDateFilter or (time >= startDate and time <= endDate)

// ╔══════════════════════════════════════════════════════════════╗
// ║                    PRESET OVERRIDES                         ║
// ╚══════════════════════════════════════════════════════════════╝
// BTC Optimized:  EMA(50/200), all filters + RSI, SL 3.0x ATR, RR 3.0 — PF 2.33, +99% PnL
// ETH Optimized:  EMA(20/200), all filters + RSI, SL 3.0x ATR, RR 2.0 — PF 1.47, +61% PnL
fastLen         = preset == "BTC Optimized" ? 50  : preset == "ETH Optimized" ? 20  : fastLen_i
useRsiFilter    = preset != "Custom" ? true : useRsiFilter_i
atrSlMultiplier = preset == "BTC Optimized" ? 3.0 : preset == "ETH Optimized" ? 3.0 : atrSlMult_i
rrRatio         = preset == "BTC Optimized" ? 3.0 : preset == "ETH Optimized" ? 2.0 : rrRatio_i

// ╔══════════════════════════════════════════════════════════════╗
// ║                    CORE CALCULATIONS                        ║
// ╚══════════════════════════════════════════════════════════════╝

// === Real Price (standard candles — works correctly on Heikin Ashi charts) ===
realClose = request.security(syminfo.tickerid, timeframe.period, close, lookahead=barmerge.lookahead_on)
realOpen  = request.security(syminfo.tickerid, timeframe.period, open,  lookahead=barmerge.lookahead_on)
realHigh  = request.security(syminfo.tickerid, timeframe.period, high,  lookahead=barmerge.lookahead_on)
realLow   = request.security(syminfo.tickerid, timeframe.period, low,   lookahead=barmerge.lookahead_on)

// === EMAs ===
emaFast = ta.ema(realClose, fastLen)
emaSlow = ta.ema(realClose, slowLen)

pFast = plot(emaFast, color=fastColor, title="Fast EMA", linewidth=2)
pSlow = plot(emaSlow, color=slowColor, title="Slow EMA", linewidth=2)
fill(pFast, pSlow, color=showEmaFill ? (emaFast > emaSlow ? color.new(color.green, 88) : color.new(color.red, 88)) : na, title="EMA Ribbon")

// === ATR ===
atrValue = ta.atr(atrLen)

// === Volume Filter ===
volumeOk = not useVolumeFilter or (volume > ta.sma(volume, 20))

// === RSI Filter ===
rsiValue  = ta.rsi(realClose, 14)
rsiBuyOk  = not useRsiFilter or (rsiValue < rsiOverbought)
rsiSellOk = not useRsiFilter or (rsiValue > rsiOversold)

// === Higher Timeframe Trend Filter ===
htfFast   = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, fastLen), lookahead=barmerge.lookahead_on)
htfSlow   = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, slowLen), lookahead=barmerge.lookahead_on)
htfBullOk = not useHtfFilter or (htfFast > htfSlow)
htfBearOk = not useHtfFilter or (htfFast < htfSlow)

// === Candle Confirmation ===
candleBuyOk  = not useCandleConfirm or (realClose > realOpen)
candleSellOk = not useCandleConfirm or (realClose < realOpen)

// === EMA Slope Filter (10-bar lookback) ===
slopeBuyOk  = not useSlopeFilter or (emaSlow > emaSlow[10])
slopeSellOk = not useSlopeFilter or (emaSlow < emaSlow[10])

// ╔══════════════════════════════════════════════════════════════╗
// ║                MARKET CONTEXT CALCULATIONS                  ║
// ╚══════════════════════════════════════════════════════════════╝

// === Auto-detect asset class ===
isCrypto = str.contains(str.lower(syminfo.type), "crypto")
isStock  = str.contains(str.lower(syminfo.type), "stock") or str.contains(str.lower(syminfo.type), "equity")

// === VIX Filter — blocks entries during high-fear environments ===
vixClose  = request.security("CBOE:VIX", "D", close, lookahead=barmerge.lookahead_on)
vixOk     = not useVixFilter or na(vixClose) or (vixClose <= vixThreshold)

// === DXY (Dollar Index) — rising dollar = headwind ===
dxyClose  = request.security("TVC:DXY", "D", close, lookahead=barmerge.lookahead_on)
dxyEma    = request.security("TVC:DXY", "D", ta.ema(close, 20), lookahead=barmerge.lookahead_on)
dxyRising = not na(dxyClose) and (dxyClose > dxyEma)

// DXY logic: rising dollar blocks longs for crypto; for stocks, less strict
dxyBuyOk  = not useDxyFilter or dxyMode == "Disabled" or na(dxyClose) ? true : dxyMode == "Auto" ? (isCrypto ? not dxyRising : true) : not dxyRising
dxySellOk = true  // rising dollar doesn't block shorts

// === BTC Dominance — for altcoins only (ETH, XRP, etc.) ===
btcDomClose   = request.security("CRYPTOCAP:BTC.D", "D", close, lookahead=barmerge.lookahead_on)
btcDomEma     = request.security("CRYPTOCAP:BTC.D", "D", ta.ema(close, btcDomLen), lookahead=barmerge.lookahead_on)
btcDomRising  = not na(btcDomClose) and (btcDomClose > btcDomEma)
isBtcItself   = str.contains(str.upper(syminfo.ticker), "BTC") and not str.contains(str.upper(syminfo.ticker), "BTC.D")

// Rising BTC.D blocks altcoin longs (money flowing to BTC, not alts)
btcDomBuyOk   = not useBtcDomFilter or not isCrypto or isBtcItself or na(btcDomClose) or not btcDomRising
btcDomSellOk  = true  // doesn't block shorts

// === SPY / QQQ Market Regime — for stocks ===
spyClose  = request.security("AMEX:SPY", "D", close, lookahead=barmerge.lookahead_on)
spyEma    = request.security("AMEX:SPY", "D", ta.ema(close, spyEmaLen), lookahead=barmerge.lookahead_on)
spyAboveEma = not na(spyClose) and (spyClose > spyEma)

// SPY above its EMA = risk-on, allow stock longs
spyBuyOk  = not useSpyFilter or not isStock or na(spyClose) or spyAboveEma
spySellOk = not useSpyFilter or not isStock or na(spyClose) or not spyAboveEma  // risk-off favors shorts

// === BTC Trend — for altcoins: BTC must be bullish ===
btcFastEma = request.security("BINANCE:BTCUSDT", "D", ta.ema(close, 50),  lookahead=barmerge.lookahead_on)
btcSlowEma = request.security("BINANCE:BTCUSDT", "D", ta.ema(close, 200), lookahead=barmerge.lookahead_on)
btcBullish = not na(btcFastEma) and (btcFastEma > btcSlowEma)

// Only blocks altcoin longs when BTC trend is bearish
btcTrendBuyOk  = not useBtcTrendFilter or not isCrypto or isBtcItself or na(btcFastEma) or btcBullish
btcTrendSellOk = true

// ╔══════════════════════════════════════════════════════════════╗
// ║                    CROSS DETECTION                          ║
// ╚══════════════════════════════════════════════════════════════╝
goldenCross = ta.crossover(emaFast, emaSlow)
deathCross  = ta.crossunder(emaFast, emaSlow)

// === Trend Conditions ===
isBullTrend = emaFast > emaSlow
isBearTrend = emaFast < emaSlow

// === Sideways Market Detection ===
emaSpreadPercent = math.abs(emaFast - emaSlow) / emaSlow
isSideways = emaSpreadPercent < (emaProximityThreshold / 100.0)

// === Price Crosses Slow EMA ===
priceCrossUpSlow   = (realClose[1] < emaSlow[1]) and realClose > emaSlow
priceCrossDownSlow = (realClose[1] > emaSlow[1]) and realClose < emaSlow

// === Price Crosses Fast EMA ===
priceCrossUpFast   = (realClose[1] < emaFast[1]) and realClose > emaFast
priceCrossDownFast = (realClose[1] > emaFast[1]) and realClose < emaFast

// ╔══════════════════════════════════════════════════════════════╗
// ║                    COOLDOWN LOGIC                           ║
// ╚══════════════════════════════════════════════════════════════╝
var int lastGreenBar = na
var int lastRedBar   = na

greenAllowed = not useCooldown or na(lastGreenBar) or (bar_index - lastGreenBar > 3)
redAllowed   = not useCooldown or na(lastRedBar)   or (bar_index - lastRedBar > 3)

// ╔══════════════════════════════════════════════════════════════╗
// ║                    SIGNAL CONDITIONS                        ║
// ╚══════════════════════════════════════════════════════════════╝
sidewaysOk = not filterSideways or not isSideways

// --- Market context combined ---
mktBuyOk  = vixOk and dxyBuyOk  and btcDomBuyOk  and spyBuyOk  and btcTrendBuyOk
mktSellOk = vixOk and dxySellOk and btcDomSellOk and spySellOk and btcTrendSellOk

// --- Slow EMA signals ---
greenTriangle = isBullTrend and priceCrossUpSlow   and greenAllowed and sidewaysOk and volumeOk and rsiBuyOk  and htfBullOk and candleBuyOk  and slopeBuyOk  and mktBuyOk  and inDateRange
redTriangle   = isBearTrend and priceCrossDownSlow and redAllowed   and sidewaysOk and volumeOk and rsiSellOk and htfBearOk and candleSellOk and slopeSellOk and mktSellOk and inDateRange

// --- Fast EMA signals ---
greenCircle = isBullTrend and priceCrossUpFast   and greenAllowed and sidewaysOk and volumeOk and rsiBuyOk  and htfBullOk and candleBuyOk  and slopeBuyOk  and mktBuyOk  and inDateRange
redCircle   = isBearTrend and priceCrossDownFast and redAllowed   and sidewaysOk and volumeOk and rsiSellOk and htfBearOk and candleSellOk and slopeSellOk and mktSellOk and inDateRange

// --- Combined entry signals ---
longEntry  = (greenTriangle or greenCircle) and (tradeDirection == "Long" or tradeDirection == "Both")
shortEntry = (redTriangle or redCircle)     and (tradeDirection == "Short" or tradeDirection == "Both")

// === Update cooldown ===
if greenTriangle or greenCircle
    lastGreenBar := bar_index
if redTriangle or redCircle
    lastRedBar := bar_index

// ╔══════════════════════════════════════════════════════════════╗
// ║                STOP LOSS / TAKE PROFIT CALC                 ║
// ╚══════════════════════════════════════════════════════════════╝
// --- Stop Loss distance ---
f_slDistance(isLong) =>
    if slType == "ATR"
        atrValue * atrSlMultiplier
    else if slType == "Percent"
        realClose * slPercent / 100.0
    else // Swing
        if isLong
            realClose - ta.lowest(realLow, swingLookback)
        else
            ta.highest(realHigh, swingLookback) - realClose

// --- Take Profit distance ---
f_tpDistance(slDist) =>
    if tpType == "Risk:Reward"
        slDist * rrRatio
    else if tpType == "ATR"
        atrValue * atrTpMultiplier
    else // Percent
        realClose * tpPercent / 100.0

// --- Trailing stop offset ---
f_trailOffset() =>
    if trailType == "ATR"
        atrValue * atrTrailMult
    else
        realClose * trailPercent / 100.0

// ╔══════════════════════════════════════════════════════════════╗
// ║                    STRATEGY EXECUTION                       ║
// ╚══════════════════════════════════════════════════════════════╝

// === Long Entry ===
if longEntry and strategy.position_size == 0
    slDist = f_slDistance(true)
    tpDist = f_tpDistance(slDist)
    
    slPrice = useStopLoss   ? realClose - slDist : na
    tpPrice = useTakeProfit ? realClose + tpDist : na
    
    strategy.entry("Long", strategy.long)
    
    if useStopLoss and useTakeProfit
        strategy.exit("Long Exit", "Long", stop=slPrice, limit=tpPrice,
             trail_points=useTrailingStop ? f_trailOffset() / syminfo.mintick : na,
             trail_offset=useTrailingStop ? f_trailOffset() / syminfo.mintick : na)
    else if useStopLoss
        strategy.exit("Long SL", "Long", stop=slPrice,
             trail_points=useTrailingStop ? f_trailOffset() / syminfo.mintick : na,
             trail_offset=useTrailingStop ? f_trailOffset() / syminfo.mintick : na)
    else if useTakeProfit
        strategy.exit("Long TP", "Long", limit=tpPrice,
             trail_points=useTrailingStop ? f_trailOffset() / syminfo.mintick : na,
             trail_offset=useTrailingStop ? f_trailOffset() / syminfo.mintick : na)
    else if useTrailingStop
        strategy.exit("Long Trail", "Long",
             trail_points=f_trailOffset() / syminfo.mintick,
             trail_offset=f_trailOffset() / syminfo.mintick)

// === Short Entry ===
if shortEntry and strategy.position_size == 0
    slDist = f_slDistance(false)
    tpDist = f_tpDistance(slDist)
    
    slPrice = useStopLoss   ? realClose + slDist : na
    tpPrice = useTakeProfit ? realClose - tpDist : na
    
    strategy.entry("Short", strategy.short)
    
    if useStopLoss and useTakeProfit
        strategy.exit("Short Exit", "Short", stop=slPrice, limit=tpPrice,
             trail_points=useTrailingStop ? f_trailOffset() / syminfo.mintick : na,
             trail_offset=useTrailingStop ? f_trailOffset() / syminfo.mintick : na)
    else if useStopLoss
        strategy.exit("Short SL", "Short", stop=slPrice,
             trail_points=useTrailingStop ? f_trailOffset() / syminfo.mintick : na,
             trail_offset=useTrailingStop ? f_trailOffset() / syminfo.mintick : na)
    else if useTakeProfit
        strategy.exit("Short TP", "Short", limit=tpPrice,
             trail_points=useTrailingStop ? f_trailOffset() / syminfo.mintick : na,
             trail_offset=useTrailingStop ? f_trailOffset() / syminfo.mintick : na)
    else if useTrailingStop
        strategy.exit("Short Trail", "Short",
             trail_points=f_trailOffset() / syminfo.mintick,
             trail_offset=f_trailOffset() / syminfo.mintick)

// === Exit on EMA Cross (trend reversal) ===
if exitOnCross
    if deathCross and strategy.position_size > 0
        strategy.close("Long", comment="Death Cross Exit")
    if goldenCross and strategy.position_size < 0
        strategy.close("Short", comment="Golden Cross Exit")

// ╔══════════════════════════════════════════════════════════════╗
// ║                    VISUAL PLOTS                             ║
// ╚══════════════════════════════════════════════════════════════╝

// === Golden / Death Cross Labels ===
plotshape(goldenCross and showLabels, title="Golden Cross", location=location.belowbar,
     style=shape.xcross, size=size.small, color=color.yellow, text="Golden", textcolor=color.white)

plotshape(deathCross and showLabels, title="Death Cross", location=location.abovebar,
     style=shape.xcross, size=size.small, color=color.red, text="Death", textcolor=color.white)

// === Slow EMA Cross Signals ===
plotshape(greenTriangle and showSlowEmaPriceCrossSignals, title="Bullish Price Cross of Slow EMA", location=location.belowbar,
     style=shape.triangleup, size=size.tiny, color=color.green)

plotshape(redTriangle and showSlowEmaPriceCrossSignals, title="Bearish Price Cross of Slow EMA", location=location.abovebar,
     style=shape.triangledown, size=size.tiny, color=color.red)

// === Fast EMA Cross Signals ===
plotshape(greenCircle and showFastEmaPriceCrossSignals, title="Bullish Price Cross of Fast EMA", location=location.belowbar,
     style=shape.circle, size=size.tiny, color=color.lime)

plotshape(redCircle and showFastEmaPriceCrossSignals, title="Bearish Price Cross of Fast EMA", location=location.abovebar,
     style=shape.circle, size=size.tiny, color=color.fuchsia)

// === Trend Background ===
bgcolor(showTrendBg ? (isBullTrend ? color.new(color.green, 95) : isBearTrend ? color.new(color.red, 95) : na) : na, title="Trend Background")

// ╔══════════════════════════════════════════════════════════════╗
// ║                  PERFORMANCE DASHBOARD                      ║
// ╚══════════════════════════════════════════════════════════════╝
if showDashboard and barstate.islastconfirmedhistory
    var table dash = table.new(position.top_right, 2, 13, bgcolor=color.new(color.black, 30), border_width=1, border_color=color.gray)

    totalTrades  = strategy.closedtrades
    winTrades    = strategy.wintrades
    lossTrades   = strategy.losstrades
    winRate      = totalTrades > 0 ? (winTrades / totalTrades) * 100 : 0.0
    netProfit    = strategy.netprofit
    netProfitPct = strategy.netprofit_percent
    maxDD        = strategy.max_drawdown
    profitFactor = strategy.grossloss != 0 ? math.abs(strategy.grossprofit / strategy.grossloss) : 0.0

    table.cell(dash, 0, 0, "Metric",        text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 40))
    table.cell(dash, 1, 0, "Value",          text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 40))
    table.cell(dash, 0, 1, "Total Trades",   text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(totalTrades),  text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 2, "Win Rate",       text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(winRate, "#.1") + "%", text_color=winRate >= 50 ? color.lime : color.orange, text_size=size.small)
    table.cell(dash, 0, 3, "Wins / Losses",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(winTrades) + " / " + str.tostring(lossTrades), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 4, "Net Profit",     text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(netProfit, "#.2"), text_color=netProfit >= 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 5, "Net Profit %",   text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(netProfitPct, "#.2") + "%", text_color=netProfitPct >= 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 6, "Max Drawdown",   text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(maxDD, "#.2"), text_color=color.red, text_size=size.small)
    table.cell(dash, 0, 7, "Profit Factor",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(profitFactor, "#.2"), text_color=profitFactor >= 1.5 ? color.lime : profitFactor >= 1.0 ? color.yellow : color.red, text_size=size.small)

    // --- Market Context rows ---
    table.cell(dash, 0, 8, "",               text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 40))
    table.cell(dash, 1, 8, "Market Context", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 40))
    table.cell(dash, 0, 9, "VIX",            text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 9, na(vixClose) ? "N/A" : str.tostring(vixClose, "#.1"), text_color=useVixFilter ? (vixOk ? color.lime : color.red) : color.gray, text_size=size.small)
    table.cell(dash, 0, 10, "DXY",           text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 10, dxyRising ? "RISING" : "FALLING", text_color=useDxyFilter ? (dxyRising ? color.red : color.lime) : color.gray, text_size=size.small)
    table.cell(dash, 0, 11, "BTC.D",         text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 11, btcDomRising ? "RISING" : "FALLING", text_color=useBtcDomFilter and isCrypto ? (btcDomRising ? color.red : color.lime) : color.gray, text_size=size.small)
    table.cell(dash, 0, 12, "SPY Regime",    text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 12, spyAboveEma ? "RISK-ON" : "RISK-OFF", text_color=useSpyFilter and isStock ? (spyAboveEma ? color.lime : color.red) : color.gray, text_size=size.small)

// ╔══════════════════════════════════════════════════════════════╗
// ║                    ALERT CONDITIONS                         ║
// ╚══════════════════════════════════════════════════════════════╝

// Slow EMA
alertcondition(greenTriangle, 
     title="BUY | Slow EMA Bullish Cross", 
     message="{{ticker}} ({{interval}}) — Price crossed ABOVE the Slow EMA in a bullish trend. Close: {{close}}")

alertcondition(redTriangle, 
     title="SELL | Slow EMA Bearish Cross", 
     message="{{ticker}} ({{interval}}) — Price crossed BELOW the Slow EMA in a bearish trend. Close: {{close}}")

alertcondition(redTriangle or greenTriangle, 
     title="SIGNAL | Slow EMA Cross", 
     message="{{ticker}} ({{interval}}) — Price crossed the Slow EMA. Close: {{close}}")

// Fast EMA
alertcondition(greenCircle, 
     title="BUY | Fast EMA Bullish Cross", 
     message="{{ticker}} ({{interval}}) — Price crossed ABOVE the Fast EMA in a bullish trend. Close: {{close}}")

alertcondition(redCircle, 
     title="SELL | Fast EMA Bearish Cross", 
     message="{{ticker}} ({{interval}}) — Price crossed BELOW the Fast EMA in a bearish trend. Close: {{close}}")

alertcondition(redCircle or greenCircle, 
     title="SIGNAL | Fast EMA Cross", 
     message="{{ticker}} ({{interval}}) — Price crossed the Fast EMA. Close: {{close}}")

// EMA Crossovers
alertcondition(goldenCross, 
     title="GOLDEN CROSS | EMA Bullish Crossover", 
     message="{{ticker}} ({{interval}}) — FAST EMA crossed ABOVE the SLOW EMA (Golden Cross).")

alertcondition(deathCross, 
     title="DEATH CROSS | EMA Bearish Crossover", 
     message="{{ticker}} ({{interval}}) — FAST EMA crossed BELOW the SLOW EMA (Death Cross).")
