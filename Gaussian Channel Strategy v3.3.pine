// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// Gaussian Channel indicator by @DonovanWall (open source) — strategy logic reverse-engineered from public description

//@version=5
strategy(title="Gaussian Channel Strategy v3.3 [RE]", overlay=true, calc_on_every_tick=false, 
     initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, 
     commission_type=strategy.commission.percent, commission_value=0.1, slippage=3, 
     fill_orders_on_standard_ohlc=true)

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Date Picker
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
startDate     = input.time(timestamp("1 January 2018 00:00 +0000"), "Start Date", group="Date Range")
endDate       = input.time(timestamp("31 Dec 2069 23:59 +0000"), "End Date", group="Date Range")
timeCondition = time >= startDate and time <= endDate

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Strategy Settings
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
enableShort = input.bool(defval=false, title="Enable Shorting", group="Strategy", tooltip="Turn on to allow short trades when downtrend is detected")

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Gaussian Channel — based on @DonovanWall's open-source indicator
// Gaussian filters are exponential moving averages applied multiple times.
// Beta and alpha are calculated based on sampling period and number of poles.
// Filtered true range generates upper/lower bands around the filter.
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------

// Filter function (courtesy of @e2e4mfck)
f_filt9x (_a, _s, _i) =>
    int _m2 = 0, int _m3 = 0, int _m4 = 0, int _m5 = 0, int _m6 = 0,
    int _m7 = 0, int _m8 = 0, int _m9 = 0, float _f = .0, _x = (1 - _a)
    _m2 := _i == 9 ? 36  : _i == 8 ? 28 : _i == 7 ? 21 : _i == 6 ? 15 : _i == 5 ? 10 : _i == 4 ? 6 : _i == 3 ? 3 : _i == 2 ? 1 : 0
    _m3 := _i == 9 ? 84  : _i == 8 ? 56 : _i == 7 ? 35 : _i == 6 ? 20 : _i == 5 ? 10 : _i == 4 ? 4 : _i == 3 ? 1 : 0
    _m4 := _i == 9 ? 126 : _i == 8 ? 70 : _i == 7 ? 35 : _i == 6 ? 15 : _i == 5 ? 5  : _i == 4 ? 1 : 0
    _m5 := _i == 9 ? 126 : _i == 8 ? 56 : _i == 7 ? 21 : _i == 6 ? 6  : _i == 5 ? 1  : 0
    _m6 := _i == 9 ? 84  : _i == 8 ? 28 : _i == 7 ? 7  : _i == 6 ? 1  : 0
    _m7 := _i == 9 ? 36  : _i == 8 ? 8  : _i == 7 ? 1  : 0
    _m8 := _i == 9 ? 9   : _i == 8 ? 1  : 0
    _m9 := _i == 9 ? 1   : 0
    _f :=   math.pow(_a, _i) * nz(_s) +
      _i  *     _x      * nz(_f[1])      - (_i >= 2 ?
      _m2 * math.pow(_x, 2)  * nz(_f[2]) : 0) + (_i >= 3 ?
      _m3 * math.pow(_x, 3)  * nz(_f[3]) : 0) - (_i >= 4 ?
      _m4 * math.pow(_x, 4)  * nz(_f[4]) : 0) + (_i >= 5 ?
      _m5 * math.pow(_x, 5)  * nz(_f[5]) : 0) - (_i >= 6 ?
      _m6 * math.pow(_x, 6)  * nz(_f[6]) : 0) + (_i >= 7 ?
      _m7 * math.pow(_x, 7)  * nz(_f[7]) : 0) - (_i >= 8 ?
      _m8 * math.pow(_x, 8)  * nz(_f[8]) : 0) + (_i == 9 ?
      _m9 * math.pow(_x, 9)  * nz(_f[9]) : 0)

f_pole (_a, _s, _i) =>
    _f1 =            f_filt9x(_a, _s, 1),      _f2 = (_i >= 2 ? f_filt9x(_a, _s, 2) : 0), _f3 = (_i >= 3 ? f_filt9x(_a, _s, 3) : 0)
    _f4 = (_i >= 4 ? f_filt9x(_a, _s, 4) : 0), _f5 = (_i >= 5 ? f_filt9x(_a, _s, 5) : 0), _f6 = (_i >= 6 ? f_filt9x(_a, _s, 6) : 0)
    _f7 = (_i >= 2 ? f_filt9x(_a, _s, 7) : 0), _f8 = (_i >= 8 ? f_filt9x(_a, _s, 8) : 0), _f9 = (_i == 9 ? f_filt9x(_a, _s, 9) : 0)
    _fn = _i == 1 ? _f1 : _i == 2 ? _f2 : _i == 3 ? _f3 :
      _i == 4     ? _f4 : _i == 5 ? _f5 : _i == 6 ? _f6 :
      _i == 7     ? _f7 : _i == 8 ? _f8 : _i == 9 ? _f9 : na
    [_fn, _f1]

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Inputs
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
src       = input(defval=hlc3, title="Source", group="Gaussian Channel")
int N     = input.int(defval=4, title="Poles", minval=1, maxval=9, group="Gaussian Channel")
int per   = input.int(defval=144, title="Sampling Period", minval=2, group="Gaussian Channel")
float mult = input.float(defval=1.414, title="Filtered True Range Multiplier", minval=0, group="Gaussian Channel")
bool modeLag  = input.bool(defval=false, title="Reduced Lag Mode", group="Gaussian Channel")
bool modeFast = input.bool(defval=false, title="Fast Response Mode", group="Gaussian Channel")

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Calculations
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
beta  = (1 - math.cos(4*math.asin(1)/per)) / (math.pow(1.414, 2/N) - 1)
alpha = -beta + math.sqrt(math.pow(beta, 2) + 2*beta)
lag   = (per - 1)/(2*N)

srcdata = modeLag ? src + (src - src[lag]) : src
trdata  = modeLag ? ta.tr(true) + (ta.tr(true) - ta.tr(true)[lag]) : ta.tr(true)

[filtn, filt1]     = f_pole(alpha, srcdata, N)
[filtntr, filt1tr] = f_pole(alpha, trdata,  N)

filt   = modeFast ? (filtn + filt1)/2 : filtn
filttr = modeFast ? (filtntr + filt1tr)/2 : filtntr

hband = filt + filttr * mult
lband = filt - filttr * mult

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Trend Detection
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
trendUp   = filt > filt[1]   // Channel is green — filter rising
trendDown = filt < filt[1]   // Channel is red   — filter falling

// Detect trend direction changes (these are the rare, high-conviction signals)
trendFlipUp   = trendUp   and not trendUp[1]    // Channel just turned green
trendFlipDown = trendDown and not trendDown[1]   // Channel just turned red

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Entry/Exit Logic — Trend direction based, trades infrequently, rides large moves
//
// The core idea from v3.3's description:
//   - Enter when a new trend is confirmed (channel flips + price confirms)
//   - Stay in as long as the trend holds (don't exit on pullbacks)
//   - Only exit on actual trend reversal
//
// This produces very few trades and captures large macro moves.
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------

// LONG: Enter when channel turns green AND price closes above the filter (confirms uptrend)
//       The close > filt check avoids entering on a brief green flicker while price is still below
longEntry  = trendUp and close > filt and (trendFlipUp or (trendFlipUp[1] and close[1] <= filt[1])) and timeCondition

// LONG EXIT: Channel turns red (trend reversal) — this is the key to riding large trends
//            We don't exit on pullbacks to the band — only on actual trend direction change
longExit   = trendFlipDown and timeCondition

// SHORT (optional): Enter when channel turns red AND price closes below the filter
shortEntry = enableShort and trendDown and close < filt and (trendFlipDown or (trendFlipDown[1] and close[1] >= filt[1])) and timeCondition

// SHORT EXIT: Channel turns green
shortExit  = enableShort and trendFlipUp and timeCondition

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Alternative entry: If the channel has been green for a while but we missed the initial flip
// (e.g., strategy started mid-trend), enter on the first close above hband as confirmation
// This is a "late entry" that still catches the trend
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
inLong     = strategy.position_size > 0
inShort    = strategy.position_size < 0
noPosition = strategy.position_size == 0

// Late long entry: Channel has been green (trending up) and price breaks above upper band — strong trend confirmation
lateLongEntry  = noPosition and not inLong and trendUp and ta.crossover(close, hband) and timeCondition

// Late short entry: Channel has been red and price breaks below lower band
lateShortEntry = enableShort and noPosition and not inShort and trendDown and ta.crossunder(close, lband) and timeCondition

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Execute Trades
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
if longEntry or lateLongEntry
    strategy.entry("Long", strategy.long)

if longExit
    strategy.close("Long")

if shortEntry or lateShortEntry
    strategy.entry("Short", strategy.short)

if shortExit
    strategy.close("Short")

//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
// Visuals
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------
color1 = #0aff68
color2 = #00752d
color3 = #ff0a5a
color4 = #990032

fcolor = filt > filt[1] ? color1 : filt < filt[1] ? color3 : #cccccc

barcolorVal = (src > src[1]) and (src > filt) and (src < hband) ? color1 :
              (src > src[1]) and (src >= hband) ? #0aff1b :
              (src <= src[1]) and (src > filt)  ? color2 :
              (src < src[1]) and (src < filt)   and (src > lband) ? color3 :
              (src < src[1]) and (src <= lband)  ? #ff0a11 :
              (src >= src[1]) and (src < filt)   ? color4 : #cccccc

filtplot  = plot(filt,  title="Filter", color=fcolor, linewidth=3)
hbandplot = plot(hband, title="Upper Band", color=fcolor)
lbandplot = plot(lband, title="Lower Band", color=fcolor)
fill(hbandplot, lbandplot, title="Channel Fill", color=color.new(fcolor, 80))
barcolor(barcolorVal)

// Entry/Exit markers
plotshape(longEntry  or lateLongEntry,  title="Long Entry",  style=shape.triangleup,   location=location.belowbar, color=#0aff68, size=size.small)
plotshape(longExit,                     title="Long Exit",   style=shape.triangledown, location=location.abovebar, color=#ff0a5a, size=size.small)
plotshape(shortEntry or lateShortEntry, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=#ff0a5a, size=size.small)
plotshape(shortExit,                    title="Short Exit",  style=shape.triangleup,   location=location.belowbar, color=#0aff68, size=size.small)
